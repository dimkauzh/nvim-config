{
  clipboard = {
    register = "unnamedplus";

    providers = {
      wl-copy.enable = true;
      xclip.enable = true;
    };
  };

  globals = {
    mapleader = " ";
  };

  colorschemes.gruvbox-baby = {
    enable = true;
  };

  opts = {
    smartindent = true;
    expandtab = true;

    tabstop = 2;
    shiftwidth = 2;
    softtabstop = 2;
  };
}
